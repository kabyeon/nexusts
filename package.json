{
  "name": "nexusts",
  "version": "0.7.0",
  "description": "NexusTS — Bun-native fullstack framework. Multi-package monorepo. See packages/* for individual modules.",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/cli/ tests/cli/",
    "lint:fix": "biome check --write src/cli/ tests/cli/",
    "nx": "bun packages/core/src/cli/index.ts",
    "examples:smoke": "vitest run tests/examples/smoke.test.ts",
    "examples:clean": "bash scripts/clean-examples.sh"
  },
  "devDependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@inertiajs/react": "^3.4.0",
    "@inertiajs/vue3": "^3.4.0",
    "@types/bun": "^1.3.0",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.18.1",
    "@vue/server-renderer": "^3.5.38",
    "eta": "^4.6.0",
    "graphql": "^17.0.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.5",
    "vue": "^3.5.38",
    "ws": "^8.21.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "license": "MIT"
}
